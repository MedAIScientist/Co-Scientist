# LLM provider keys — set the one matching `[llm] provider` in your config.
#   provider = "anthropic"          → ANTHROPIC_API_KEY
#   provider = "openai"             → OPENAI_API_KEY
#   provider = "openai_compatible"  → set OPENAI_API_KEY to your endpoint's
#                                     key (or any value for keyless local
#                                     endpoints like Ollama) and set
#                                     [llm.openai] base_url accordingly.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# OPENAI_BASE_URL=                  # optional; overrides [llm.openai] base_url

# Embeddings (Voyage primary, OpenAI fallback — reuses OPENAI_API_KEY above)
VOYAGE_API_KEY=

# Web search (Tavily primary, Brave fallback)
TAVILY_API_KEY=
BRAVE_API_KEY=

# Optional: improves PubMed / OpenAlex rate limits
NCBI_API_KEY=
OPENALEX_API_KEY=
